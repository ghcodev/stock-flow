# ============================================================
# StockFlow API — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# ============================================================

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stockflow

# JWT — use um secret longo e aleatório em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-secret-longo-e-aleatorio
JWT_EXPIRES_IN=8h

# Servidor
PORT=3000
