# ============================================================
# StockFlow API - variaveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# ============================================================

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stockflow
DATABASE_URL="mysql://user:pass@localhost:3306/stockflow?charset=utf8mb4"

# JWT - use um secret longo e aleatorio em producao
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-uma-string-aleatoria-de-64-chars-minimo
JWT_EXPIRES_IN=8h

# Servidor
PORT=3000
FRONTEND_URL=http://localhost:5173

# Ambiente
NODE_ENV=development
